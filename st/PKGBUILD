# Maintainer: welpyes
pkgname=st
_pkgname=st
pkgver=0.1.0.r1.g1ae1082
pkgrel=1
pkgdesc="Fast feature rich ST patchset"
arch=('aarch64' 'x86_64')
url="https://github.com/welpyes/st"
license=('GPL2')
makedepends=( 'clang' 'make' 'libx11' 'libxrender' 'pkg-config' 'imlib2' 'fontconfig' 'harfbuzz' 'freetype' 'libxft')
provides=("${_pkgname}")
conflicts=("${_pkgname}")
source=("git+${url}.git#branch=master")
sha256sums=('SKIP')

pkgver() {
  cd "${srcdir}/${_pkgname}"
  printf "0.1.0.r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "${srcdir}/${_pkgname}"
  make
}

package() {
  cd "${srcdir}/${_pkgname}"
  DESTDIR="${pkgdir}" make install PREFIX=$PREFIX
}

